{
  "manifest_version": 3,
  "name": "Bolor AI Extension",
  "version": "0.0.1",
  "description": "Mongolian galig to cyrillic and spelling correction",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
